:8080 {
    @claims_launcher path /claims /claims/
    handle @claims_launcher {
        reverse_proxy server:3000
    }

    @claims_editor_entry path /claims/new /claims/new/* /claims/s /claims/s/*
    handle @claims_editor_entry {
        rewrite * /claims-app/
        reverse_proxy claims-client:8082
    }

    @claims_editor_assets path /claims-app /claims-app/*
    handle @claims_editor_assets {
        reverse_proxy claims-client:8082
    }

    @api path /api/*
    handle @api {
        reverse_proxy server:3000
    }

    handle {
        reverse_proxy client:8081
    }
}
