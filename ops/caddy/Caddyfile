{
    servers {
        trusted_proxies static private_ranges
        trusted_proxies_strict
    }
    email {$ACME_EMAIL}
}

{$MAP_DOMAIN:map.example.com} {
    encode zstd gzip
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    route {
        @internalIngest path /api/internal/ingest/*
        @internalIngestViaIris path /iris/api/internal/ingest/*
        @metrics path /api/metrics /metrics /iris/metrics /iris/api/metrics
        respond @internalIngest 403
        respond @internalIngestViaIris 403
        respond @metrics 403

        # Allow reporter traffic on the map domain.
        # - https://map.example.com/v1/*
        # - https://map.example.com/iris/v1/* (subdirectory mode)
        @ingestSubdir path /iris/*
        handle @ingestSubdir {
            uri strip_prefix /iris
            reverse_proxy ingest:3010
        }

        @ingestV1 path /v1/*
        handle @ingestV1 {
            reverse_proxy ingest:3010
        }

        @sse path /api/events
        handle @sse {
            reverse_proxy server:3000 {
                flush_interval -1
            }
        }

        handle {
            reverse_proxy server:3000
        }
    }
}

{$IRIS_DOMAIN:iris.example.com} {
    encode zstd gzip
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    route {
        @internalIngest path /api/internal/ingest/*
        @metrics path /metrics /api/metrics
        respond @internalIngest 403
        respond @metrics 403
        reverse_proxy ingest:3010
    }
}
